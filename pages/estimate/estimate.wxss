/* pages/estimate/estimate.wxss */

page {
  background: #f5f5f5;
}

/* 页面标题 */
.header {
  padding: 16rpx 0 12rpx 0;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  text-align: center;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 卡片通用 */
.card {
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

/* 油价参考卡片 */
.price-ref-card {
  padding: 20rpx 32rpx;
}

.price-ref-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-ref-label {
  font-size: 28rpx;
  color: #666;
}

.price-ref-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1890ff;
}

.price-ref-tip {
  font-size: 22rpx;
  color: #fa8c16;
  margin-top: 6rpx;
}

.price-ref-loading {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 表单卡片 */
.form-card {
  padding: 8rpx 32rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

.form-input {
  padding: 24rpx 28rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-top: 8rpx;
  justify-content: center;
}

.btn-clear,
.btn-calc {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0;
  margin: 0;
}

.btn-clear {
  background: #d9d9d9;
  color: #333;
  border: none;
}

.btn-calc {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border: none;
}

/* 结果卡片 */
.result-card {
  border-top: 4rpx solid #1890ff;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-row:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 28rpx;
  color: #666;
}

.result-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.result-cost {
  color: #f5222d;
  font-size: 44rpx;
}

/* 说明卡片 */
.note-card {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
}

.note-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d48806;
  margin-bottom: 16rpx;
}

.note-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.note-content text {
  font-size: 24rpx;
  color: #ad8b00;
  line-height: 1.6;
}
